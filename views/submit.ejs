<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>💖🎀 Submit an adorable kitty UwU 🎀💖</title>
    <style>
      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }
      body {
        background-image: url("https://media.giphy.com/media/xT0Gqz4x4eLd5gDtaU/giphy.gif"); /* Use this beautiful heart-filled background 💖 */
        background-repeat: no-repeat;
        background-size: cover;
        color: #000000;
        text-align: center; /* Beautiful center alignment like the submit button */
      }
      h1 {
        text-align: center;
        padding: 20px;
        font-size: 36px;
        font-family: "Comic Sans MS", cursive, sans-serif;
        animation: bounce 1s infinite;
      }
      form {
        margin: 0 auto;
        width: 300px;
      }
      .home-button {
        background-color: #ffb6c1; /* Same cute pink background as the submit button! */
        color: #000000; /* Nice dark text color UwU */
        text-decoration: none; /* No yucky underline */
        padding: 15px 32px; /* Same soft padding for comfort */
        text-align: center; /* Beautiful center alignment like the submit button */
        border: none; /* No borders necessary, it's cuter this way! */
        margin-top: 90px; /* Some space above the button so it's not cramped uwu */
      }
    </style>
  </head>
  <body>
    <h1>💖🎀🐈✨💃🐾Submit an adowabuw kitty!🐾💃✨🐈🎀💖</h1>
    <form action="/submit" method="post" enctype="multipart/form-data">
      <input type="file" name="kitty" required />
      <button
        type="submit"
        style="
          background-color: #ffb6c1;
          color: #000000;
          border: none;
          padding: 15px 32px;
          text-align: center;
          display: inline-block;
          font-size: 16px;
        "
      >
        💖🎀🐈✨Submit Kitty✨🐈🎀💖
      </button>
    </form>
    <br />
    <br />
    <a href="/" class="home-button">💖🎀🏡✨Back to home✨🏡🎀💖</a>
  </body>
</html>
